# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# local scratch / reverse-engineering artifacts (may contain secrets)
/.scratch/
/discover-bird.mjs
/submit-bird-templates.mjs

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# remotion pre-build bundle (generated by scripts/bundle-remotion.ts)
.remotion/

# typescript
*.tsbuildinfo
next-env.d.ts

# local reference documents (client spreadsheets, pricing calculators, etc.)
# these are business-sensitive binary files — keep out of git history
References/

# supabase CLI scratch (linked-project metadata, gen-types cache)
supabase/.temp/

# Personal accounting — must never be committed
vat_q*_2026_receipts/
vat_q*_2027_receipts/
*_receipts/Q*_reference_only/

# Local scratchpad — not part of the repo
Crowd photos/
Images/
*_ticket_audit_*.md
CC_PROMPT_*.md
CURSOR_PROMPT_*.md
WC26_funnel_xref_*.xlsx
