# Copy to .env.local and fill values. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Symmetric key for pgcrypto on `d2c_connections.credentials_encrypted` (migration 042).
# Same rules as EVENTBRITE_TOKEN_KEY: random string, ≥32 chars recommended.
D2C_TOKEN_KEY=

FEATURE_D2C_LIVE=false

CRON_SECRET=

# Optional overrides for /api/cron/benchmark-alerts (defaults are conservative).
# BENCHMARK_ALERT_FATIGUE_FREQ_MIN=3.5
# BENCHMARK_ALERT_FATIGUE_CTR_RATIO=0.7
# BENCHMARK_ALERT_SCALING_CPC_RATIO=0.5
# BENCHMARK_ALERT_SCALING_MIN_CLICKS=1000
# BENCHMARK_ALERT_CPA_RATIO=2
# BENCHMARK_ALERT_STALLED_SPEND_MIN=100
# BENCHMARK_ALERT_AUDIENCE_CPC_HIGH_RATIO=2.5
# BENCHMARK_ALERT_AUDIENCE_CPC_LOW_RATIO=0.5
# BENCHMARK_ALERT_AUDIENCE_MIN_SPEND=50
# BENCHMARK_ALERT_BREAKOUT_MIN_REGS=25

# TikTok Business API OAuth + encrypted credential storage (migration 054).
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URI=
TIKTOK_TOKEN_KEY=
OFFPIXEL_META_AUDIENCE_WRITES_ENABLED=false

# 4thefans booking API encrypted credential storage.
# Random string, >=32 chars recommended.
FOURTHEFANS_TOKEN_KEY=
FOURTHEFANS_API_BASE=https://4thefans.book.tickets/wp-json/agency/v1
